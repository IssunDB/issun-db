digraph IssunDBArchitecture {
    fontname = "Helvetica,Arial,sans-serif"
    layout = dot
    rankdir = RL
    ranksep = 1.1
    nodesep = 0.5
    splines = true
    bgcolor = "white"
    compound = true

    node [
    fontname = "Helvetica,Arial,sans-serif",
    shape = rect,
    style = "filled",
    color = "#475569",
    fillcolor = "white",
    penwidth = 1.4,
    margin = "0.16,0.10"
    ]

    edge [
    fontname = "Helvetica,Arial,sans-serif",
    fontsize = 10,
    color = "#475569",
    fontcolor = "#475569",
    penwidth = 1.2
    ]

    // ---------------------------------------------------------------
 // GraphBLAS foundation: raw FFI and safe wrapper.
 // ---------------------------------------------------------------
    subgraph cluster_graphblas {
    label = "GraphBLAS Wapper"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#0891B2"
    penwidth = 1.4
    margin = 16

    graphblas_sys [label = "issundb-graphblas-sys", fillcolor = "#CFFAFE", color = "#0891B2"]
    graphblas [label = "issundb-graphblas", fillcolor = "#CFFAFE", color = "#0891B2"]
    }

    // ---------------------------------------------------------------
 // Storage engine: the foundation crate.
 // ---------------------------------------------------------------
    subgraph cluster_core {
    label = "Storage Engine"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#2563EB"
    penwidth = 1.4
    margin = 16

    core [label = "issundb-core", fillcolor = "#DBEAFE", color = "#2563EB"]
    }

    // ---------------------------------------------------------------
 // Extension crates: depend on core, never on each other upward.
 // ---------------------------------------------------------------
    subgraph cluster_ext {
    label = "Extension Crates"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#65A30D"
    penwidth = 1.4
    margin = 16

    vector [label = "issundb-vector", fillcolor = "#ECFCCB", color = "#65A30D"]
    text [label = "issundb-text", fillcolor = "#ECFCCB", color = "#65A30D"]
    retrieval [label = "issundb-retrieval", fillcolor = "#D9F99D", color = "#4D7C0F"]
    cypher [label = "issundb-cypher", fillcolor = "#D9F99D", color = "#4D7C0F"]
    }

    // ---------------------------------------------------------------
 // Public facade.
 // ---------------------------------------------------------------
    subgraph cluster_facade {
    label = "Public Facade"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#D97706"
    penwidth = 1.4
    margin = 16

    facade [label = "issundb", fillcolor = "#FEF3C7", color = "#D97706"]
    }

    // ---------------------------------------------------------------
 // Consumers: bindings, servers, tools. Facade-only.
 // ---------------------------------------------------------------
    subgraph cluster_consumers {
    label = "Consumer Crates"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#7C3AED"
    penwidth = 1.4
    margin = 16

    cli [label = "issundb-cli", fillcolor = "#E9D5FF", color = "#7C3AED"]
    rest [label = "issundb-rest", fillcolor = "#E9D5FF", color = "#7C3AED"]
    mcp [label = "issundb-mcp", fillcolor = "#E9D5FF", color = "#7C3AED"]
    py_bind [label = "issundb-py", fillcolor = "#E9D5FF", color = "#7C3AED"]
    examples [label = "issundb-examples", fillcolor = "#E9D5FF", color = "#7C3AED"]
    }

    // ---------------------------------------------------------------
 // Dependency edges (point from dependent to dependency).
 // lhead/ltail clip the edge at the cluster border (compound = true)
 // so arrows attach to the enclosing cluster, not the inner box.
 // ---------------------------------------------------------------

    // GraphBLAS internal edge.
    graphblas -> graphblas_sys

    // Core depends on the safe GraphBLAS wrapper.
    core -> graphblas [lhead = cluster_graphblas]

    // Extension crates depend on core.
    vector -> core [lhead = cluster_core]
    text -> core [lhead = cluster_core]
    retrieval -> core [lhead = cluster_core]
    retrieval -> vector
    retrieval -> text
    cypher -> core [lhead = cluster_core]
    cypher -> text

    // Facade composes the extensions and core.
    facade -> core [ltail = cluster_facade, lhead = cluster_core]
    facade -> vector [ltail = cluster_facade, lhead = cluster_ext]

    // Consumers depend only on the facade.
    cli -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    rest -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    mcp -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    py_bind -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    examples -> facade [ltail = cluster_consumers, lhead = cluster_facade]
}
