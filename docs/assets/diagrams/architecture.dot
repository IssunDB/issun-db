digraph IssunDBArchitecture {
    fontname = "Helvetica,Arial,sans-serif"
    layout = dot
    rankdir = RL
    ranksep = 1.1
    nodesep = 0.5
    splines = true
    bgcolor = "white"
    compound = true

    node [
    fontname = "Helvetica,Arial,sans-serif",
    shape = rect,
    style = "filled",
    color = "#475569",
    fillcolor = "white",
    penwidth = 1.4,
    margin = "0.16,0.10"
    ]

    edge [
    fontname = "Helvetica,Arial,sans-serif",
    fontsize = 10,
    color = "#475569",
    fontcolor = "#475569",
    penwidth = 1.2
    ]

    // ---------------------------------------------------------------
    // Storage engine: the foundation crate.
    // ---------------------------------------------------------------
    subgraph cluster_core {
    label = "Storage Engine"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#2563EB"
    penwidth = 1.4
    margin = 16

    core [label = "issundb-core", fillcolor = "#DBEAFE", color = "#2563EB"]
    }

    // ---------------------------------------------------------------
    // Extension crates: depend on core, never on each other upward.
    // ---------------------------------------------------------------
    subgraph cluster_ext {
    label = "Extension Crates"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#65A30D"
    penwidth = 1.4
    margin = 16

    vector [label = "issundb-vector", fillcolor = "#ECFCCB", color = "#65A30D"]
    text [label = "issundb-text", fillcolor = "#ECFCCB", color = "#65A30D"]
    retrieval [label = "issundb-retrieval", fillcolor = "#D9F99D", color = "#4D7C0F"]
    cypher [label = "issundb-cypher", fillcolor = "#D9F99D", color = "#4D7C0F"]
    }

    // ---------------------------------------------------------------
    // Public facade.
    // ---------------------------------------------------------------
    subgraph cluster_facade {
    label = "Public Facade"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#D97706"
    penwidth = 1.4
    margin = 16

    facade [label = "issundb", fillcolor = "#FEF3C7", color = "#D97706"]
    }

    // ---------------------------------------------------------------
    // Consumers: bindings, servers, tools. Facade-only.
    // ---------------------------------------------------------------
    subgraph cluster_consumers {
    label = "Consumers"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#7C3AED"
    penwidth = 1.4
    margin = 16

    cli [label = "issundb-cli", fillcolor = "#E9D5FF", color = "#7C3AED"]
    server [label = "issundb-server", fillcolor = "#E9D5FF", color = "#7C3AED"]
    mcp [label = "issundb-mcp", fillcolor = "#E9D5FF", color = "#7C3AED"]
    gui [label = "issundb-gui", fillcolor = "#E9D5FF", color = "#7C3AED"]
    node_bind [label = "issundb-node", fillcolor = "#E9D5FF", color = "#7C3AED"]
    py_bind [label = "issundb-py", fillcolor = "#E9D5FF", color = "#7C3AED"]
    }

    // ---------------------------------------------------------------
    // Test fixtures: depend on core, never imported by production.
    // ---------------------------------------------------------------
    subgraph cluster_testing {
    label = "Test Support"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#DB2777"
    penwidth = 1.4
    margin = 16

    testing [label = "issundb-testing", fillcolor = "#FCE7F3", color = "#DB2777"]
    }

    // ---------------------------------------------------------------
    // Dependency edges (point from dependent to dependency).
    // lhead/ltail clip the edge at the cluster border (compound = true)
    // so arrows attach to the enclosing cluster, not the inner box.
    // ---------------------------------------------------------------
    vector -> core [lhead = cluster_core]
    text -> core [lhead = cluster_core]
    retrieval -> core [lhead = cluster_core]
    retrieval -> vector
    retrieval -> text
    cypher -> core [lhead = cluster_core]

    facade -> core [ltail = cluster_facade, lhead = cluster_core]
    facade -> vector [ltail = cluster_facade, lhead = cluster_ext]

    cli -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    server -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    mcp -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    gui -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    node_bind -> facade [ltail = cluster_consumers, lhead = cluster_facade]
    py_bind -> facade [ltail = cluster_consumers, lhead = cluster_facade]

    testing -> core [ltail = cluster_testing, lhead = cluster_core, style = dashed]
}
