digraph IssunDBArchitecture {
    fontname = "Helvetica,Arial,sans-serif"
    layout = dot
    rankdir = LR
    ranksep = 1.1
    nodesep = 0.5
    splines = true
    bgcolor = "white"
    compound = true

    node [
    fontname = "Helvetica,Arial,sans-serif",
    shape = rect,
    style = "filled",
    color = "#475569",
    fillcolor = "white",
    penwidth = 1.4,
    margin = "0.16,0.10"
    ]

    edge [
    fontname = "Helvetica,Arial,sans-serif",
    fontsize = 10,
    color = "#475569",
    fontcolor = "#475569",
    penwidth = 1.2
    ]

    // ---------------------------------------------------------------
    // Storage engine: the foundation crate.
    // ---------------------------------------------------------------
    subgraph cluster_core {
    label = "issundb-core (storage engine)"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#2563EB"
    penwidth = 1.4
    margin = 16

    core_graph [label = "Graph\n(node/edge CRUD, adjacency, algos)", fillcolor = "#DBEAFE", color = "#2563EB"]
    core_storage [label = "Storage\n(LMDB env, 12 sub-databases)", fillcolor = "#E0F2FE", color = "#0284C7"]
    core_csr [label = "CSR snapshot\n(arc-swap hot read path)", fillcolor = "#F8FAFC", color = "#64748B"]
    core_gblas [label = "GraphBLAS\n(traversal, analytics, paths, flow)", fillcolor = "#F8FAFC", color = "#64748B"]

    core_graph -> core_storage [label = "owns"]
    core_graph -> core_csr [label = "rebuilds"]
    core_csr -> core_gblas [label = "materializes"]
    }

    // ---------------------------------------------------------------
    // Extension crates: depend on core, never on each other upward.
    // ---------------------------------------------------------------
    subgraph cluster_ext {
    label = "Extension Crates"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#65A30D"
    penwidth = 1.4
    margin = 16

    vector [label = "issundb-vector\nVectorGraphExt: upsert_vector, vector_search", fillcolor = "#ECFCCB", color = "#65A30D"]
    text [label = "issundb-text\nTextGraphExt / TextIndexExt: text_search", fillcolor = "#ECFCCB", color = "#65A30D"]
    retrieval [label = "issundb-retrieval\nretrieve, retrieve_with -> Subgraph", fillcolor = "#D9F99D", color = "#4D7C0F"]
    cypher [label = "issundb-cypher\nparser, planner, optimizer, executor", fillcolor = "#D9F99D", color = "#4D7C0F"]
    }

    // ---------------------------------------------------------------
    // Public facade.
    // ---------------------------------------------------------------
    subgraph cluster_facade {
    label = "Public Facade"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#D97706"
    penwidth = 1.4
    margin = 16

    facade [label = "issundb\nre-exports Graph, Error, Hit,\nretrieval + Cypher types, GraphQueryExt", fillcolor = "#FEF3C7", color = "#D97706"]
    }

    // ---------------------------------------------------------------
    // Consumers: bindings, servers, tools. Facade-only.
    // ---------------------------------------------------------------
    subgraph cluster_consumers {
    label = "Consumers (facade only)"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#7C3AED"
    penwidth = 1.4
    margin = 16

    cli [label = "issundb-cli\nREPL", fillcolor = "#E9D5FF", color = "#7C3AED"]
    server [label = "issundb-server\nAxum REST /v1", fillcolor = "#E9D5FF", color = "#7C3AED"]
    mcp [label = "issundb-mcp\nMCP (stdio / HTTP)", fillcolor = "#E9D5FF", color = "#7C3AED"]
    gui [label = "issundb-gui\negui desktop", fillcolor = "#E9D5FF", color = "#7C3AED"]
    node_bind [label = "issundb-node\nNAPI-RS", fillcolor = "#E9D5FF", color = "#7C3AED"]
    py_bind [label = "issundb-py\nPyO3", fillcolor = "#E9D5FF", color = "#7C3AED"]
    }

    // ---------------------------------------------------------------
    // Test fixtures: depend on core, never imported by production.
    // ---------------------------------------------------------------
    subgraph cluster_testing {
    label = "Test Support"
    fontname = "Helvetica,Arial,sans-serif"
    fontsize = 14
    style = "rounded"
    color = "#DB2777"
    penwidth = 1.4
    margin = 16

    testing [label = "issundb-testing\nopen_tmp, chain, clique, diamond", fillcolor = "#FCE7F3", color = "#DB2777"]
    }

    // ---------------------------------------------------------------
    // Dependency edges (point from dependent to dependency).
    // ---------------------------------------------------------------
    vector -> core_graph [lhead = cluster_core]
    text -> core_graph [lhead = cluster_core]
    retrieval -> core_graph [lhead = cluster_core]
    retrieval -> vector
    retrieval -> text
    cypher -> core_graph [lhead = cluster_core, label = "public API"]

    facade -> core_graph [lhead = cluster_core]
    facade -> vector [ltail = cluster_facade, lhead = cluster_ext]

    cli -> facade [lhead = cluster_facade]
    server -> facade [lhead = cluster_facade]
    mcp -> facade [lhead = cluster_facade]
    gui -> facade [lhead = cluster_facade]
    node_bind -> facade [lhead = cluster_facade]
    py_bind -> facade [lhead = cluster_facade]

    testing -> core_graph [lhead = cluster_core, style = dashed, label = "fixtures"]
}
