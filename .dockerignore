# Keep the build context lean. The build needs every workspace crate's
# Cargo.toml, the sources, and the committed Cargo.lock; everything below is
# either rebuilt, irrelevant to a release build, or large test fixtures.

# Rust build output (rebuilt inside the image).
/target
**/target

# Version control and editor or tooling state.
.git
.github
.vscode
.idea
.claude
.agents
.codex
.antigravitycli

# Python tooling for the dataset scripts (not needed to build the binaries).
.venv
venv
__pycache__
*.pyc

# Docs and the excluded LadybugDB comparison harness, which is not part of the
# workspace build.
docs
benchmarks/ladybugdb-compare/target

# Container and meta files.
Dockerfile
.dockerignore
*.md
LICENSE*
